config {
  type: "table",
  schema: "lw",
  name: "final_table",
  bigquery: {
    partitionBy: "DATE(date_updated)"
  }
}
SELECT
  * EXCEPT(row_num)
FROM (
  SELECT
    *,
    ROW_NUMBER() OVER (
      PARTITION BY unique_id 
      ORDER BY date_updated DESC
    ) AS row_num
  FROM
    ${ref("lw_orderitems")}
)
WHERE
  row_num = 1